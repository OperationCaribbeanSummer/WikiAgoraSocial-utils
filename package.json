  "main": "src/index.js",
  "files": [
    "src/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "audit": "npm audit",
    "build": "echo 'No build step required - ES modules'",
    "bundle-analyzer": "npx webpack-bundle-analyzer",
    "clean": "rm -rf node_modules package-lock.json",
    "coverage": "vitest --coverage",
    "depcheck": "npx depcheck --ignores='@operationcaribbeansummer/*'",
    "dev": "node --watch src/index.js",
    "docs": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "standard src/**/*.js",
    "lint:fix": "standard --fix src/**/*.js",
    "outdated": "npm outdated",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm run test",
    "publish": "npm publish",
    "size": "npx size-limit",
    "sort": "npx sort-package-json",
    "start": "node --watch src/index.js",
    "test": "vitest",
    "test:e2e": "vitest --testPattern=e2e",
    "todo": "node run CHECKLIST-scrypt.sh",
    "update-deps": "npm update && npm audit fix"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "fs-extra": "^11.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.19.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.10",
    "redis": "^5.9.0",
    "redoc-express": "^2.1.3",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "uuid": "^13.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
