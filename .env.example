# ============================================
# Application Configuration - Server & Environment
# ============================================
APP_NAME=WikiAgora
NODE_ENV=development
PORT=4444
HOST=0.0.0.0
API_URL=https://44.org/api/
API_PREFIX=/api/v1
CORS_ORIGIN=https://44.org,http://localhost:4444
TRUST_PROXY=1

# ============================================
# Database Configuration
# ============================================
MONGO_URI=mongodb://localhost:27017/WikiAgora
DB_HOST=localhost
DB_PORT=27017
DB_NAME=WikiAgora
DB_USER=admin
DB_PASSWORD=<PASSWORD>

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<PASSWORD>
REDIS_DB=0
REDIS_URL=redis://:<PASSWORD>@localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# ============================================
# Kafka
# ============================================
KAFKA_CLIENT_ID=express44
KAFKA_BROKERS=localhost:9092
KAFKA_SSL=true
KAFKA_USERNAME=
KAFKA_PASSWOR=<PASSWORD>
KAFKA_TOPIC_PREFIX=wa_

# ============================================
# socket.io
# ============================================
SOCKET_CORS_ORIGIN=http://localhost:4444

# ============================================
# Security & Authentication
# ============================================
JWT_SECRET=44444444444444444444444444444444444444444444
JWT_REFRESH_SECRET=44444444444444444444444444444444444444444444
JWT_EXPIRES_IN=44h
JWT_REFRESH_EXPIRES_IN=44d
SESSION_SECRET=44444444444444444444444444444444444444444444
BCRYPT_SALT_ROUNDS=12

# ============================================
# Rate limiting
# ============================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info

# ============================================
# OpenTelemetry
# ============================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=express-api
OTEL_SERVICE_VERSION=1.0.0
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production
# Optional: Authentication for OTLP exporter
OTEL_EXPORTER_AUTH_TOKEN=<your-token-here>

# ============================================
# Production Specific
# ============================================
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pem
COMPRESSION_ENABLED=true

# ============================================
# Feature Flags
# ============================================
ENABLE_NEW_FEATURE=true
MAINTENANCE_MODE=false

# ============================================
# Email
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=youremail@example.com
EMAIL_PASSWORD=<PASSWORD>
EMAIL_FROM=noreply@OperationCaribbeanSummer.org

# ============================================
# Payment Processors
# ============================================
STRIPE_SECRET_KEY=sk_xxxx
STRIPE_PUBLIC_KEY=pk_xxxx
STRIPE_WEBHOOK_SECRET=whsec_<SECRET>
PAYPAL_CLIENT_ID=<ID>
PAYPAL_CLIENT_SECRET=<SECRET>

# ============================================
# Social Auth / Connections
# ============================================
FACEBOOK_APP_ID=<ID>
FACEBOOK_APP_SECRET=<SECRET> # FACEBOOK_SECRET=
GITHUB_CLIENT_ID=<ID>
GITHUB_SECRET=<SECRET> # GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=<ID>.apps.googleusercontent.com
GOOGLE_SECRET=<SECRET> # GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=<ID>
LINKEDIN_SECRET=<SECRET>
TELEGRAM_CLIENT_ID=<ID>
TELEGRAM_SECRET=<SECRET>
TWITTER_CLIENT_ID=<ID>
TWITTER_SECRET=<SECRET> # TWITTER_CLIENT_SECRET=

# ============================================
# APIs
# ============================================
